<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Romão Cred | Empresa Simples de Crédito</title>
    <style>
        :root {
            --bg-dark: #0d0d0d;
            --panel-dark: #141414;
            --border-color: #262626;
            --text-silver: #e5e5e5;
            --text-muted: #8c8c8c;
            --platinum: #cfcfcf;
            --platinum-accent: #ffffff;
            --success: #22c55e;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-silver);
            line-height: 1.6;
            padding: 0;
            margin: 0;
        }

        /* Top Bar Branding baseado na logo original */
        header {
            background-color: var(--bg-dark);
            padding: 50px 20px 30px 20px;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
        }

        .brand-container {
            display: inline-block;
            text-align: center;
        }

        .brand-main {
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--platinum-accent);
            text-transform: uppercase;
            margin-bottom: 2px;
        }

        .brand-sub {
            font-size: 0.85rem;
            letter-spacing: 4px;
            color: var(--text-muted);
            text-transform: uppercase;
            border-top: 1px solid var(--border-color);
            padding-top: 8px;
            margin-top: 5px;
        }

        .container {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }

        .pitch-text {
            text-align: center;
            font-size: 0.95rem;
            color: var(--text-muted);
            margin: 10px 0 25px 0;
        }

        .simulator-card {
            background: var(--panel-dark);
            border-radius: 12px;
            padding: 30px 24px;
            border: 1px solid var(--border-color);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        }

        .input-group {
            margin-bottom: 28px;
        }

        .label-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        label {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-silver);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .value-display {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--platinum-accent);
        }

        input[type="range"] {
            -webkit-appearance: none;
            width: 100%;
            height: 4px;
            border-radius: 2px;
            background: var(--border-color);
            outline: none;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--platinum-accent);
            border: 2px solid var(--bg-dark);
            cursor: pointer;
            transition: transform 0.1s ease;
        }

        input[type="range"]::-webkit-slider-thumb:hover {
            transform: scale(1.15);
        }

        .results-panel {
            background: #181818;
            border-radius: 8px;
            padding: 20px;
            margin-top: 25px;
            border: 1px solid var(--border-color);
        }

        .result-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .result-row:last-of-type {
            border-bottom: none;
            padding-top: 15px;
        }

        .result-label {
            font-size: 0.85rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .result-value {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-silver);
        }

        .result-value.highlight {
            font-size: 1.6rem;
            color: var(--platinum-accent);
            font-weight: 700;
            border-bottom: 1px dashed var(--text-muted);
        }

        .btn-action {
            display: block;
            width: 100%;
            background-color: var(--text-silver);
            color: var(--bg-dark);
            text-align: center;
            padding: 16px;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 700;
            text-decoration: none;
            margin-top: 25px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: background 0.2s;
        }

        .btn-action:hover {
            background-color: var(--platinum-accent);
        }

        .payment-notice {
            margin-top: 20px;
            background: rgba(34, 197, 94, 0.05);
            border: 1px solid rgba(34, 197, 94, 0.15);
            border-radius: 6px;
            padding: 12px;
            font-size: 0.8rem;
            color: #4ade80;
            text-align: center;
        }

        footer {
            text-align: center;
            padding: 40px 20px;
            font-size: 0.75rem;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }
    </style>
</head>
<body>

    <header>
        <div class="brand-container">
            <div class="brand-main">[%] Romão</div>
            <div class="brand-sub">Empresa Simples de Crédito</div>
        </div>
    </header>

    <div class="container">
        <p class="pitch-text">Crédito estruturado, ágil e focado no fluxo de caixa de lojistas e empresários.</p>

        <div class="simulator-card">
            <!-- Input Valor -->
            <div class="input-group">
                <div class="label-container">
                    <label for="amount">Capital Solicitado</label>
                    <span class="value-display" id="amount-label">R$ 1.000</span>
                </div>
                <input type="range" id="amount" min="500" max="20000" step="100" value="1000">
            </div>

            <!-- Input Semanas -->
            <div class="input-group">
                <div class="label-container">
                    <label for="weeks">Prazo de Amortização</label>
                    <span class="value-display" id="weeks-label">4 semanas</span>
                </div>
                <input type="range" id="weeks" min="1" max="10" step="1" value="4">
            </div>

            <!-- Resultados -->
            <div class="results-panel">
                <div class="result-row">
                    <span class="result-label">Encargo Semanal</span>
                    <span class="result-value" id="rate-display">3,0% p/ sem</span>
                </div>
                <div class="result-row">
                    <span class="result-label">Montante Total</span>
                    <span class="result-value" id="total-display">R$ 1.120,00</span>
                </div>
                <div class="result-row">
                    <span class="result-label">Parcela Fixa Semanal</span>
                    <span class="result-value highlight" id="installment-display">R$ 280,00</span>
                </div>
            </div>

            <!-- Botão de Ação -->
            <a href="#" id="whatsapp-link" target="_blank" class="btn-action">
                Solicitar Proposta Comercial
            </a>

            <div class="payment-notice">
                🔒 Amortização integrada via Pix Dinâmico e link de pagamento recorrente.
            </div>
        </div>

        <footer>
            <p>&copy; 2026 Romão Cred. Operações exclusivas nos termos da Lei Complementar nº 167/2019.</p>
        </footer>
    </div>

    <script>
        const amountInput = document.getElementById('amount');
        const weeksInput = document.getElementById('weeks');
        const amountLabel = document.getElementById('amount-label');
        const weeksLabel = document.getElementById('weeks-label');
        
        const rateDisplay = document.getElementById('rate-display');
        const totalDisplay = document.getElementById('total-display');
        const installmentDisplay = document.getElementById('installment-display');
        const whatsappLink = document.getElementById('whatsapp-link');

        // SUBSTITUA ABAIXO PELO SEU NÚMERO DO WHATSAPP DO COMERCIAL COM DDD
        // (Apenas números, coloque o 55 da frente, ex: 5562999999999)
        const WHATSAPP_NUMBER = "5562999999999"; 

        function formatCurrency(value) {
            return value.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        function updateSimulator() {
            const amount = parseFloat(amountInput.value);
            let weeks = parseInt(weeksInput.value);
            let rate = 0;

            if (amount >= 500 && amount <= 10000) {
                weeksInput.max = 10;
                if (weeks > 10) { weeks = 10; weeksInput.value = 10; }
            } else if (amount >= 10001 && amount <= 20000) {
                weeksInput.max = 16;
            }

            if (amount >= 500 && amount <= 5000) {
                rate = (weeks <= 5) ? 0.03 : 0.04;
            } else if (amount >= 5001 && amount <= 10000) {
                rate = (weeks <= 5) ? 0.025 : 0.035;
            } else if (amount >= 10001 && amount <= 20000) {
                rate = (weeks <= 8) ? 0.02 : 0.025;
            }

            const totalInterest = rate * weeks;
            const totalToPay = amount * (1 + totalInterest);
            const installment = totalToPay / weeks;

            amountLabel.textContent = formatCurrency(amount);
            weeksLabel.textContent = `${weeks} ${weeks === 1 ? 'semana' : 'semanas'}`;
            rateDisplay.textContent = `${(rate * 100).toFixed(1).replace('.', ',')}% p/ sem`;
            totalDisplay.textContent = formatCurrency(totalToPay);
            installmentDisplay.textContent = formatCurrency(installment);

            const msg = `Olá, gostaria de formalizar a proposta de crédito PJ calculada no simulador:\\n\\n` +
                        `• Valor Solicitado: ${formatCurrency(amount)}\\n` +
                        `• Prazo Escolhido: ${weeks} semanas\\n` +
                        `• Parcela Semanal: ${formatCurrency(installment)}\\n` +
                        `• Custo Total: ${formatCurrency(totalToPay)}`;

            whatsappLink.href = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;
        }

        amountInput.addEventListener('input', updateSimulator);
        weeksInput.addEventListener('input', updateSimulator);
        window.onload = updateSimulator;
    </script>
</body>
</html>
